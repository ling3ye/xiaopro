---
/**
 * 耗材参数对比 - 独立页面
 *
 * 从 URL 参数读取选中的耗材 ID，展示完整对比表格
 * URL 格式: /printing/filaments/compare?item1=xxx&item2=xxx
 *
 * @route /[lang]/printing/filaments/compare
 */

import Layout from '../../../../layouts/Layout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getLocalizedPath } from '../../../../utils/i18n';
import { languages } from '../../../../i18n/config';
import type { SupportedLocale } from '../../../../i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLocale: SupportedLocale = lang as SupportedLocale;
const t = useTranslations(currentLocale);

const allFilaments = await getCollection('filaments');

const categoryNames: Record<string, string> = {
  pla: t('filament.category.pla'),
  petg: t('filament.category.petg'),
  abs: t('filament.category.abs'),
  tpu: t('filament.category.tpu'),
  nylon: t('filament.category.nylon'),
  pc: t('filament.category.pc'),
  asa: t('filament.category.asa'),
  other: t('filament.category.other'),
};

const getLocalizedSpecs = (specs: any) => {
  if (!specs) return {};
  if (typeof specs === 'object' && !Array.isArray(specs) && Object.keys(specs).some(k => ['zh-cn', 'zh-tw', 'en', 'ja'].includes(k))) {
    return specs[currentLocale] || specs['zh-cn'] || specs['en'] || {};
  }
  return specs;
};

const allData = JSON.stringify(Object.fromEntries(
  allFilaments.map(f => [f.id, {
    name: `${f.data.brand || ''} ${f.data.model}`.trim(),
    brand: f.data.brand || '',
    model: f.data.model,
    category: categoryNames[f.data.category] || f.data.category,
    priceRange: f.data.priceRange || '',
    image: f.data.image || '',
    link: getLocalizedPath(`/printing/filaments/${f.id}`, currentLocale),
    specs: getLocalizedSpecs(f.data.specs),
  }])
));

const breadcrumbItems = [
  { label: t('nav.home'), href: getLocalizedPath('/', currentLocale) },
  { label: t('nav.printing'), href: getLocalizedPath('/printing', currentLocale) },
  { label: t('printing.filaments'), href: getLocalizedPath('/printing/filaments', currentLocale) },
  { label: t('compare.title') },
];
---

<Layout
  title={`${t('compare.title')} - ${t('printing.filaments')}`}
  description={t('filament.listDescription')}
  lang={lang}
  currentPath={`/${lang}/printing/filaments/compare`}
>
  <div class="container">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <section class="compare-page">
    <div class="container">
      <header class="compare-header">
        <h1 class="compare-title">{t('compare.title')} - {t('printing.filaments')}</h1>
        <a href={getLocalizedPath('/printing/filaments', currentLocale)} class="compare-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/>
          </svg>
          {t('filament.backToList')}
        </a>
      </header>

      <div id="compare-content" class="compare-content">
        <p class="compare-empty">{t('compare.selectHint')}</p>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ allData }}>
  function renderCompare() {
    const params = new URLSearchParams(window.location.search);
    const ids = [];
    for (const [key, value] of params) {
      if (key.startsWith('item') && value) ids.push(decodeURIComponent(value));
    }

    const container = document.getElementById('compare-content');
    if (!container || ids.length < 2) return;

    const data = typeof allData === 'string' ? JSON.parse(allData) : allData;
    const items = ids.map(id => data[id]).filter(Boolean);
    if (items.length < 2) {
      container.innerHTML = '<p class="compare-empty">未找到选中的产品数据，请返回列表页重新选择。</p>';
      return;
    }

    const allKeys = new Set();
    items.forEach(item => { if (item.specs) Object.keys(item.specs).forEach(k => allKeys.add(k)); });

    const colCount = items.length;
    const labelColWidth = 140;
    const itemColWidth = `1fr`;
    let html = `<div class="compare-cards" style="grid-template-columns: ${labelColWidth}px repeat(${colCount}, ${itemColWidth})">`;
    html += '<div class="compare-card compare-card--label"></div>';
    items.forEach(item => {
      html += `
        <div class="compare-card">
          ${item.image ? `<img src="${item.image}" alt="${item.name}" class="compare-card__image" />` : '<div class="compare-card__placeholder">🧵</div>'}
          ${item.brand ? `<div class="compare-card__brand">${item.brand}</div>` : ''}
          <h3 class="compare-card__model">${item.model}</h3>
          ${item.priceRange ? `<div class="compare-card__price">${item.priceRange}</div>` : ''}
          <div class="compare-card__category">${item.category}</div>
          <a href="${item.link}" class="compare-card__link">查看详情 →</a>
        </div>`;
    });
    html += '</div>';

    html += '<div class="compare-table-wrapper"><table class="compare-table" style="table-layout: fixed;">';
    html += `<colgroup><col style="width: ${labelColWidth}px" />`;
    items.forEach(() => { html += '<col />'; });
    html += '</colgroup>';
    html += '<thead><tr><th class="compare-table__label-col">参数</th>';
    items.forEach(item => { html += `<th>${item.model}</th>`; });
    html += '</tr></thead><tbody>';

    allKeys.forEach(key => {
      const values = items.map(item => item.specs?.[key] || '—');
      const allSame = values.length > 1 && values.every(v => v === values[0]);

      // 检测数值并找出最大值
      const numValues = values.map(v => {
        const m = String(v).match(/[-+]?[\d.]+/);
        return m ? parseFloat(m[0]) : NaN;
      });
      const hasNumbers = numValues.some(n => !isNaN(n));
      const allNumeric = numValues.every(n => !isNaN(n));
      let maxIdx = -1;
      if (hasNumbers && !allSame) {
        const maxVal = Math.max(...numValues.filter(n => !isNaN(n)));
        // 只有当最大值唯一时才高亮
        const maxIndices = numValues.reduce((acc, n, i) => { if (n === maxVal) acc.push(i); return acc; }, []);
        if (maxIndices.length === 1) maxIdx = maxIndices[0];
      }

      html += `<tr class="${allSame ? 'compare-table__row--same' : 'compare-table__row--diff'}">`;
      html += `<td class="compare-table__label">${key}</td>`;
      values.forEach((v, i) => {
        const isMax = i === maxIdx;
        const cls = [
          'compare-table__value',
          !allSame && !isMax ? 'compare-table__value--highlight' : '',
          isMax ? 'compare-table__value--best' : '',
        ].filter(Boolean).join(' ');
        html += `<td class="${cls}">${v}</td>`;
      });
      html += '</tr>';
    });

    html += '</tbody></table></div>';
    container.innerHTML = html;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderCompare);
  } else {
    renderCompare();
  }
</script>

<style is:global>
  .compare-page { padding: var(--space-3xl) 0; }
  .compare-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-2xl); flex-wrap: wrap; gap: var(--space-md); }
  .compare-title { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--color-text-primary); }
  .compare-back { display: inline-flex; align-items: center; gap: var(--space-xs); padding: 8px 16px; background: var(--color-bg-tertiary); border: 1px solid var(--color-border); border-radius: var(--radius-md); color: var(--color-text-secondary); text-decoration: none; font-size: var(--text-sm); transition: all var(--transition-fast); }
  .compare-back:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .compare-back svg { width: 16px; height: 16px; }

  .compare-content { min-height: 200px; }
  .compare-empty { text-align: center; color: var(--color-text-tertiary); padding: var(--space-5xl, 128px) 0; font-size: var(--text-lg); }

  .compare-cards { display: grid; gap: 1px; margin-bottom: 0; background: var(--color-border); border: 1px solid var(--color-border); border-bottom: none; border-radius: var(--radius-lg) var(--radius-lg) 0 0; overflow: hidden; }
  .compare-card { text-align: center; padding: var(--space-md) var(--space-sm); background: var(--color-bg-secondary); }
  .compare-card__image { width: 80px; height: 80px; object-fit: contain; margin: 0 auto var(--space-xs); }
  .compare-card__placeholder { font-size: 2rem; margin-bottom: var(--space-xs); }
  .compare-card__brand { font-size: var(--text-xs); color: var(--color-primary); text-transform: uppercase; font-weight: 600; }
  .compare-card__model { font-size: var(--text-sm); font-weight: 700; color: var(--color-text-primary); margin: 2px 0; }
  .compare-card__price { font-size: var(--text-base); font-weight: 700; color: var(--color-success); margin-bottom: 2px; }
  .compare-card__category { font-size: var(--text-xs); color: var(--color-text-tertiary); margin-bottom: var(--space-xs); }
  .compare-card__link { font-size: var(--text-xs); color: var(--color-primary); text-decoration: none; }
  .compare-card__link:hover { text-decoration: underline; }

  .compare-table-wrapper { overflow-x: auto; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); border-radius: 0 0 var(--radius-lg) var(--radius-lg); overflow: hidden; }
  .compare-card--label { background: var(--color-bg-tertiary); }
  .compare-table th, .compare-table td { padding: var(--space-sm) var(--space-md); border: 1px solid var(--color-border); text-align: left; transition: background 0.25s ease, box-shadow 0.25s ease; }
  .compare-table tbody tr { transition: background 0.25s ease, box-shadow 0.25s ease; }
  .compare-table tbody tr:hover { background: rgba(99, 102, 241, 0.18); box-shadow: inset 0 0 0 1px rgba(99, 102, 241, 0.25); }
  .compare-table tbody tr:hover td { border-color: rgba(99, 102, 241, 0.15); }
  .compare-table tbody tr.compare-table__row--diff:hover { background: rgba(0, 255, 136, 0.18); box-shadow: inset 0 0 0 1px rgba(0, 255, 136, 0.25); }
  .compare-table tbody tr.compare-table__row--diff:hover td { border-color: rgba(0, 255, 136, 0.15); }
  .compare-table tbody tr:hover td.compare-table__value--best { background: rgba(0, 255, 136, 0.28); }
  .compare-table th { background: var(--color-bg-tertiary); font-weight: 600; color: var(--color-text-primary); }
  .compare-table__label-col { width: 160px; min-width: 120px; }
  .compare-table__label { color: var(--color-text-tertiary); font-weight: 500; white-space: nowrap; }
  .compare-table__value { color: var(--color-text-primary); }
  .compare-table__value--highlight { color: var(--color-primary); font-weight: 600; }
  .compare-table__value--best { background: rgba(0, 255, 136, 0.12); color: var(--color-success); font-weight: 700; position: relative; }
  .compare-table__value--best::after { content: ' ★'; font-size: 0.7em; }
  .compare-table__row--diff { background: rgba(0, 255, 136, 0.05); }
</style>
