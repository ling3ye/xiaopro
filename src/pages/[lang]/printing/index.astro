---
/**
 * 3D打印 - 中心页面
 *
 * 3D打印资源的总览页面，展示打印机、耗材、模型三个子栏目入口
 * 支持多语言路由
 *
 * @route /[lang]/printing/
 *
 * @author Claude Code
 * @version 1.0.0
 */

import Layout from '../../../layouts/Layout.astro';
import Card from '../../../components/Card.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getLocalizedPath } from '../../../utils/i18n';
import { languages } from '../../../i18n/config';
import type { SupportedLocale } from '../../../i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLocale: SupportedLocale = lang as SupportedLocale;
const t = useTranslations(currentLocale);

// Get counts for each sub-section
const printers = await getCollection('printers');
const filaments = await getCollection('filaments');
const models = await getCollection('models', ({ id }) => id.startsWith(`${lang}/`));

const breadcrumbItems = [
  { label: t('nav.home'), href: getLocalizedPath('/', currentLocale) },
  { label: t('nav.printing'), href: getLocalizedPath('/printing', currentLocale) },
];

const subSections = [
  {
    key: 'printers',
    title: t('printing.printers'),
    description: t('printer.listDescription'),
    count: printers.length,
    link: getLocalizedPath('/printing/printers', currentLocale),
    exploreText: t('printing.explorePrinters'),
    color: 'var(--color-primary)',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>`,
  },
  {
    key: 'filaments',
    title: t('printing.filaments'),
    description: t('filament.listDescription'),
    count: filaments.length,
    link: getLocalizedPath('/printing/filaments', currentLocale),
    exploreText: t('printing.exploreFilaments'),
    color: 'var(--color-success)',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/></svg>`,
  },
  {
    key: 'models',
    title: t('printing.models'),
    description: t('model.listDescription'),
    count: models.length,
    link: getLocalizedPath('/printing/models', currentLocale),
    exploreText: t('printing.exploreModels'),
    color: 'var(--color-warning)',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
];
---

<Layout
  title={t('printing.title')}
  description={t('printing.description')}
  lang={lang}
  currentPath={`/${lang}/printing`}
>
  <!-- 面包屑导航 -->
  <div class="container">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <section class="printing-hub">
    <div class="container">
      <!-- Hero -->
      <header class="printing-hero">
        <div class="printing-hero__icon">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="12 18 12 4 36 4 36 18"/>
            <path d="M12 36H8a4 4 0 0 1-4-4V22a4 4 0 0 1 4-4h32a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4h-4"/>
            <rect x="12" y="28" width="24" height="16"/>
            <line x1="18" y1="34" x2="30" y2="34"/>
            <line x1="18" y1="38" x2="26" y2="38"/>
          </svg>
        </div>
        <h1 class="printing-hero__title">{t('printing.title')}</h1>
        <p class="printing-hero__description">{t('printing.description')}</p>
      </header>

      <!-- 子栏目卡片 -->
      <div class="printing-sections">
        {subSections.map(section => (
          <a href={section.link} class="section-card">
            <div class="section-card__icon" style={`color: ${section.color}`} set:html={section.icon} />
            <div class="section-card__content">
              <h2 class="section-card__title">{section.title}</h2>
              <p class="section-card__description">{section.description}</p>
              <div class="section-card__meta">
                <span class="section-card__count">{section.count}</span>
                <span class="section-card__explore">
                  {section.exploreText}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14"/>
                    <path d="M12 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .printing-hub {
    padding: var(--space-3xl) 0;
  }

  .printing-hero {
    text-align: center;
    margin-bottom: var(--space-5xl, 96px);
  }

  .printing-hero__icon {
    width: 80px;
    height: 80px;
    margin: 0 auto var(--space-lg);
    color: var(--color-primary);
  }

  .printing-hero__icon svg {
    width: 100%;
    height: 100%;
  }

  .printing-hero__title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: var(--space-md);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-success) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .printing-hero__description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .printing-sections {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .printing-sections {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .section-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-2xl);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .section-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-glow);
  }

  .section-card__icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .section-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .section-card__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .section-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }

  .section-card__description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .section-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .section-card__count {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .section-card__explore {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
  }

  .section-card__explore svg {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-fast);
  }

  .section-card:hover .section-card__explore svg {
    transform: translateX(4px);
  }
</style>
