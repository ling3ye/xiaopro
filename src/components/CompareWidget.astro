---
/**
 * 对比组件 CompareWidget (v4 - 规范化属性对比)
 *
 * v4 变更:
 * - 使用 canonical spec ID 替代语言相关的 key
 * - 属性数据为结构化对象 {value, unit, test_method, ...}
 * - 对比表格使用统一的 spec label 映射
 * - 兼容旧 localStorage 格式, 自动清理
 *
 * @component CompareWidget
 *
 * Props:
 * @property {string} collectionType - 'printers' | 'filaments'
 * @property {string} locale - 当前语言
 *
 * @author Claude Code
 * @version 4.0.0
 */

import { useTranslations, getLocalizedPath } from '../utils/i18n';
import type { SupportedLocale } from '../i18n/config';
import { specLabels } from '../content/filaments/spec-labels';
import { specPropertyMeta } from '../content/filaments/spec-registry';

interface Props {
  collectionType: 'printers' | 'filaments';
  locale: SupportedLocale;
}

const { collectionType, locale } = Astro.props;
const t = useTranslations(locale);

const comparePagePath = getLocalizedPath(
  collectionType === 'printers' ? '/printing/printers/compare' : '/printing/filaments/compare',
  locale
);

// Build spec labels for client-side JS
const specLabelsForJs: Record<string, string> = {};
if (collectionType === 'filaments') {
  for (const [id, localeMap] of Object.entries(specLabels)) {
    specLabelsForJs[id] = localeMap[locale] || localeMap['en'] || id;
  }
}
const specLabelsJson = JSON.stringify(specLabelsForJs);
---

<div class="compare-host"
  data-collection-type={collectionType}
  data-spec-labels={collectionType === 'filaments' ? specLabelsJson : '{}'}
  style="display:none;"
></div>

<!-- 对比浮动栏 (always rendered, JS controls visibility) -->
<div class="compare-bar" id="compare-bar" style="display:none;">
  <div class="compare-bar__inner">
    <div class="compare-bar__info">
      <span class="compare-bar__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="18"/>
          <rect x="14" y="3" width="7" height="18"/>
        </svg>
      </span>
      <span class="compare-bar__count" id="compare-count">0</span>
      <span class="compare-bar__label">{t('compare.title')}</span>
    </div>
    <div class="compare-bar__items" id="compare-items"></div>
    <div class="compare-bar__actions">
      <button class="compare-bar__btn compare-bar__btn--start" id="compare-start" disabled>
        {t('compare.startCompare')}
      </button>
      <a class="compare-bar__btn compare-bar__btn--page" id="compare-page-link" href={comparePagePath} style="display:none;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
      <button class="compare-bar__btn compare-bar__btn--clear" id="compare-clear">
        {t('compare.clear')}
      </button>
    </div>
  </div>
</div>

<!-- 对比表格弹窗（快速预览） -->
<div class="compare-modal" id="compare-modal" style="display:none;">
  <div class="compare-modal__overlay" id="compare-overlay"></div>
  <div class="compare-modal__content">
    <div class="compare-modal__header">
      <h2 class="compare-modal__title">{t('compare.title')}</h2>
      <button class="compare-modal__close" id="compare-close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="compare-modal__body" id="compare-body"></div>
    <div class="compare-modal__footer">
      <a class="compare-modal__full-link" id="compare-full-link" href={comparePagePath}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 3h6v6"/><path d="M9 21H3v-6"/>
          <path d="M21 3l-7 7"/><path d="M3 21l7-7"/>
        </svg>
        打开完整对比页面
      </a>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var MAX_COMPARE = 4;
  var hostEl = document.querySelector('.compare-host');
  var collectionType = hostEl ? hostEl.getAttribute('data-collection-type') : 'printers';
  var STORAGE_KEY = 'compare_' + collectionType;

  // Load spec labels from data attribute (for filaments)
  var specLabels = {};
  try {
    var labelsStr = hostEl ? hostEl.getAttribute('data-spec-labels') : '{}';
    specLabels = JSON.parse(labelsStr || '{}');
  } catch(e) {}

  function getStorage() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { return []; }
  }
  function setStorage(items) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
  }
  function getSpecs() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY + '_specs') || '{}'); } catch(e) { return {}; }
  }
  function setSpecs(data) {
    localStorage.setItem(STORAGE_KEY + '_specs', JSON.stringify(data));
  }
  function getNames() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY + '_names') || '{}'); } catch(e) { return {}; }
  }
  function setNames(data) {
    localStorage.setItem(STORAGE_KEY + '_names', JSON.stringify(data));
  }

  /**
   * Migrate old localStorage format (string values) to new format.
   * Old: { id: { "Tensile Strength": "53 MPa", ... } }
   * New: { id: { "tensile_strength_xy": { value: 53, unit: "MPa" }, ... } }
   * Detect old format: values are strings, not objects with .value
   */
  function migrateOldFormat() {
    var specs = getSpecs();
    var needsMigrate = false;
    for (var id in specs) {
      var itemProps = specs[id];
      for (var key in itemProps) {
        if (typeof itemProps[key] === 'string') {
          needsMigrate = true;
          break;
        }
      }
      if (needsMigrate) break;
    }
    if (needsMigrate) {
      // Clear old data — user needs to re-add items
      localStorage.removeItem(STORAGE_KEY + '_specs');
    }
  }

  // Helper: get display value from property object
  function getDisplayValue(prop) {
    if (!prop) return '—';
    var raw = prop.value;
    if (typeof raw === 'number') {
      var unit = prop.unit ? ' ' + prop.unit : '';
      var cond = prop.condition ? ' (' + prop.condition + ')' : '';
      return raw + unit + cond;
    }
    return String(raw);
  }

  // Helper: get numeric value
  function getNumericValue(prop) {
    if (!prop) return NaN;
    if (typeof prop.value === 'number') return prop.value;
    return NaN;
  }

  function initCompare() {
    // Migrate old localStorage format if needed
    migrateOldFormat();

    var bar = document.getElementById('compare-bar');
    var modal = document.getElementById('compare-modal');
    var countEl = document.getElementById('compare-count');
    var itemsEl = document.getElementById('compare-items');
    var startBtn = document.getElementById('compare-start');
    var pageLink = document.getElementById('compare-page-link');
    var clearBtn = document.getElementById('compare-clear');
    var overlay = document.getElementById('compare-overlay');
    var closeBtn = document.getElementById('compare-close');
    var bodyEl = document.getElementById('compare-body');
    var fullLink = document.getElementById('compare-full-link');

    // Load persisted selections
    var selectedItems = getStorage();

    // Inject properties data from list page into localStorage
    var pageSpecs = window.__compareSpecsData;
    if (pageSpecs && Object.keys(pageSpecs).length > 0) {
      var storedSpecs = getSpecs();
      for (var k in pageSpecs) { storedSpecs[k] = pageSpecs[k]; }
      setSpecs(storedSpecs);
      var storedNames = getNames();
      document.querySelectorAll('[data-compare-id] .compare-item-name').forEach(function(el) {
        var parent = el.closest('[data-compare-id]');
        var id = parent ? parent.dataset.compareId : '';
        if (id && el.textContent) storedNames[id] = el.textContent;
      });
      setNames(storedNames);
    }

    // Sync checkboxes with persisted state
    document.querySelectorAll('.compare-checkbox').forEach(function(cb) {
      var input = cb;
      var id = input.dataset.compareId || '';
      if (selectedItems.indexOf(id) !== -1) {
        input.checked = true;
      }
    });

    // --- Compare bar logic ---
    function updateBar() {
      if (!bar || !countEl || !itemsEl || !startBtn) return;

      if (selectedItems.length > 0) {
        bar.style.display = 'block';
      } else {
        bar.style.display = 'none';
        if (modal) modal.style.display = 'none';
      }
      countEl.textContent = String(selectedItems.length);
      startBtn.disabled = selectedItems.length < 2;

      var names = getNames();
      itemsEl.innerHTML = '';
      selectedItems.forEach(function(id) {
        var chip = document.createElement('span');
        chip.className = 'compare-bar__chip';
        chip.textContent = names[id] || id;
        itemsEl.appendChild(chip);
      });

      if (pageLink) {
        pageLink.style.display = selectedItems.length >= 2 ? 'inline-flex' : 'none';
        var params = selectedItems.map(function(id, i) { return 'item' + (i+1) + '=' + encodeURIComponent(id); }).join('&');
        pageLink.href = pageLink.href.split('?')[0] + '?' + params;
      }

      // Sync checkboxes when bar updates
      document.querySelectorAll('.compare-checkbox').forEach(function(cb) {
        var input = cb;
        var id = input.dataset.compareId || '';
        input.disabled = selectedItems.length >= MAX_COMPARE && selectedItems.indexOf(id) === -1;
        input.checked = selectedItems.indexOf(id) !== -1;
      });
    }

    function showComparison() {
      if (!bodyEl || selectedItems.length < 2) return;
      var specs = getSpecs();
      var names = getNames();

      // Collect all canonical property IDs
      var allPropIds = [];
      var seenIds = {};
      selectedItems.forEach(function(id) {
        var itemProps = specs[id] || {};
        for (var k in itemProps) {
          if (!seenIds[k]) {
            seenIds[k] = true;
            allPropIds.push(k);
          }
        }
      });

      var html = '<div class="compare-table-wrapper"><table class="compare-table">';
      html += '<thead><tr><th class="compare-table__label-col"></th>';
      selectedItems.forEach(function(id) { html += '<th class="compare-table__item-col">' + (names[id] || id) + '</th>'; });
      html += '</tr></thead><tbody>';

      allPropIds.forEach(function(propId) {
        var props = selectedItems.map(function(id) { return (specs[id] && specs[id][propId]) ? specs[id][propId] : null; });
        var values = props.map(function(p) { return getDisplayValue(p); });
        var allSame = values.length > 1 && values.every(function(v) { return v === values[0]; });

        // Check test_method differences
        var testMethods = props.map(function(p) { return p && p.test_method ? p.test_method : ''; });
        var hasMethodDiff = testMethods.some(function(m, i) { return m && m !== testMethods[0]; });

        // Best value highlighting for numeric properties
        var numValues = props.map(function(p) { return getNumericValue(p); });
        var hasNumbers = numValues.some(function(n) { return !isNaN(n); });
        var maxIdx = -1;
        if (hasNumbers && !allSame) {
          var validNums = numValues.filter(function(n) { return !isNaN(n); });
          var maxVal = Math.max.apply(null, validNums);
          var maxIndices = numValues.reduce(function(acc, n, i) { if (n === maxVal) acc.push(i); return acc; }, []);
          if (maxIndices.length === 1) maxIdx = maxIndices[0];
        }

        var label = specLabels[propId] || propId;
        html += '<tr class="' + (allSame ? 'compare-table__row--same' : 'compare-table__row--diff') + '">';
        html += '<td class="compare-table__label">' + label + '</td>';
        values.forEach(function(v, i) {
          var isMax = i === maxIdx;
          var cls = 'compare-table__value';
          if (!allSame && !isMax) cls += ' compare-table__value--highlight';
          if (isMax) cls += ' compare-table__value--best';

          var methodNote = '';
          if (hasMethodDiff && testMethods[i]) {
            methodNote = ' <span class="compare-table__method">(' + testMethods[i] + ')</span>';
          }

          html += '<td class="' + cls + '">' + v + methodNote + '</td>';
        });
        html += '</tr>';
      });

      html += '</tbody></table></div>';
      bodyEl.innerHTML = html;

      if (fullLink) {
        var params = selectedItems.map(function(id, i) { return 'item' + (i+1) + '=' + encodeURIComponent(id); }).join('&');
        fullLink.href = fullLink.href.split('?')[0] + '?' + params;
      }
      if (modal) modal.style.display = 'flex';
    }

    function clearAll() {
      selectedItems.length = 0;
      setStorage(selectedItems);
      document.querySelectorAll('.compare-checkbox').forEach(function(cb) {
        cb.checked = false;
        cb.disabled = false;
      });
      updateBar();
    }

    // Wire up bar events
    if (bar) {
      document.querySelectorAll('.compare-checkbox').forEach(function(checkbox) {
        checkbox.addEventListener('change', function() {
          var id = checkbox.dataset.compareId || '';
          if (checkbox.checked) {
            if (selectedItems.length >= MAX_COMPARE) { checkbox.checked = false; return; }
            if (selectedItems.indexOf(id) === -1) selectedItems.push(id);
          } else {
            var idx = selectedItems.indexOf(id);
            if (idx > -1) selectedItems.splice(idx, 1);
          }
          setStorage(selectedItems);
          updateBar();
        });
      });

      if (startBtn) startBtn.addEventListener('click', showComparison);
      if (clearBtn) clearBtn.addEventListener('click', clearAll);
      if (overlay) overlay.addEventListener('click', function() { if (modal) modal.style.display = 'none'; });
      if (closeBtn) closeBtn.addEventListener('click', function() { if (modal) modal.style.display = 'none'; });

      // Show bar if items exist (works on ALL pages: list + detail)
      updateBar();
    }

    // --- Detail page "add to compare" button ---
    var addBtn = document.getElementById('detail-add-compare');
    if (addBtn) {
      var itemId = addBtn.dataset.itemId || '';
      var itemName = addBtn.dataset.itemName || '';
      var itemPropsStr = addBtn.dataset.itemSpecs || '{}';

      // Sync button state with persisted selections
      if (selectedItems.indexOf(itemId) !== -1) {
        addBtn.classList.add('detail-compare-btn--added');
      }

      addBtn.addEventListener('click', function() {
        var idx = selectedItems.indexOf(itemId);
        if (idx > -1) {
          selectedItems.splice(idx, 1);
          addBtn.classList.remove('detail-compare-btn--added');
        } else {
          if (selectedItems.length >= MAX_COMPARE) return;
          selectedItems.push(itemId);
          try {
            var storedSpecs = getSpecs();
            storedSpecs[itemId] = JSON.parse(itemPropsStr);
            setSpecs(storedSpecs);
          } catch(e) {}
          var storedNames = getNames();
          storedNames[itemId] = itemName;
          setNames(storedNames);
          addBtn.classList.add('detail-compare-btn--added');
        }
        setStorage(selectedItems);
        updateBar();
      });
    }
  }

  window.__compareSpecsData = window.__compareSpecsData || {};

  // Use requestAnimationFrame to ensure DOM is fully rendered
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      requestAnimationFrame(initCompare);
    });
  } else {
    requestAnimationFrame(initCompare);
  }
})();
</script>

<style>
  /* Hidden host for data passing */
  .compare-host { display: none !important; }

  .compare-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-bg-elevated);
    border-top: 2px solid var(--color-primary);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.3);
    animation: slideUp 0.3s ease;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  .compare-bar__inner {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-md) var(--space-lg);
  }

  .compare-bar__info {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .compare-bar__icon { width: 24px; height: 24px; color: var(--color-primary); }

  .compare-bar__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .compare-bar__label { font-weight: 600; color: var(--color-text-primary); white-space: nowrap; }
  .compare-bar__items { display: flex; gap: var(--space-sm); flex: 1; overflow-x: auto; }
  .compare-bar__chip {
    padding: 4px 12px;
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .compare-bar__actions { display: flex; gap: var(--space-sm); flex-shrink: 0; }
  .compare-bar__btn {
    padding: 8px 20px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    border: none;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .compare-bar__btn--start { background: var(--color-primary); color: white; }
  .compare-bar__btn--start:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
  .compare-bar__btn--start:disabled { opacity: 0.4; cursor: not-allowed; }

  .compare-bar__btn--page {
    background: var(--color-bg-tertiary);
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
  }
  .compare-bar__btn--page:hover { background: var(--color-primary); color: white; }
  .compare-bar__btn--page svg { width: 16px; height: 16px; }

  .compare-bar__btn--clear {
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }
  .compare-bar__btn--clear:hover { color: var(--color-error); border-color: var(--color-error); }

  /* Modal */
  .compare-modal { position: fixed; inset: 0; z-index: 200; display: none; align-items: center; justify-content: center; }
  .compare-modal__overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.7); }
  .compare-modal__content {
    position: relative;
    width: 95%;
    max-width: 1000px;
    max-height: 85vh;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .compare-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }
  .compare-modal__title { font-size: var(--text-xl); font-weight: 700; color: var(--color-text-primary); }
  .compare-modal__close {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    border-radius: var(--radius-md);
    background: var(--color-bg-tertiary);
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .compare-modal__close:hover { color: var(--color-error); background: var(--color-bg-secondary); }
  .compare-modal__close svg { width: 20px; height: 20px; }
  .compare-modal__body { padding: var(--space-lg); overflow-y: auto; }
  .compare-modal__footer {
    padding: var(--space-md) var(--space-lg);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: center;
  }
  .compare-modal__full-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px 24px;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
  }
  .compare-modal__full-link:hover { opacity: 0.9; transform: translateY(-1px); }
  .compare-modal__full-link svg { width: 18px; height: 18px; }

  /* Table */
  .compare-table-wrapper { overflow-x: auto; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .compare-table th, .compare-table td { padding: var(--space-sm) var(--space-md); border: 1px solid var(--color-border); text-align: left; }
  .compare-table th { background: var(--color-bg-tertiary); font-weight: 600; color: var(--color-text-primary); position: sticky; top: 0; }
  .compare-table__label-col { width: 180px; min-width: 140px; }
  .compare-table__label { color: var(--color-text-tertiary); font-weight: 500; white-space: normal; word-break: break-word; line-height: 1.4; }
  .compare-table__value { color: var(--color-text-primary); }
  .compare-table__value--highlight { color: var(--color-primary); font-weight: 500; }
  .compare-table__value--best { background: rgba(0, 255, 136, 0.12); color: var(--color-success); font-weight: 700; }
  .compare-table__row--diff { background: rgba(0, 212, 255, 0.03); }
  .compare-table__method { font-size: 0.8em; color: var(--color-text-tertiary); font-style: italic; }
</style>
