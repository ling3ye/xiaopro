---
/**
 * 页脚组件 Footer
 *
 * 网站底部区域，包含品牌信息、友情链接、社交媒体、版权信息
 *
 * @component Footer
 *
 * Props:
 * @property {string} lang - 当前语言代码
 *
 * @author Claude Code
 * @version 2.0.0
 */

import { useTranslations, getLocalizedPath } from '../utils/i18n';

// 获取组件属性
interface Props {
  lang?: string;
}

const { lang = 'zh-cn' } = Astro.props;

// 获取翻译函数
const t = useTranslations(lang as any);

// 当前年份
const currentYear = new Date().getFullYear();

// 社交媒体配置
const socialLinks = [
  {
    name: 'GitHub',
    url: 'https://github.com/ling3ye',
  },
  {
    name: 'YouTube',
    url: 'https://www.youtube.com/@lingshunlab',
  },
];

// 友情链接配置
const friendLinks = [
  {
    name: 'lingshunLAB',
    url: 'https://www.lingshunlab.com',
  },
  {
    name: 'Maker Onsite',
    url: 'https://makeronsite.com',
  },
  {
    name: 'Free AI Tool',
    url: 'https://freeaitool.com',
  },
  {
    name: 'Dashen Tech',
    url: 'https://dashen-tech.com',
  },
];

// 社交媒体图标 SVG
const socialIcons: Record<string, string> = {
  'GitHub': `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  'YouTube': `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
};
---

<footer class="footer">
  <div class="footer__inner">
    <!-- 品牌信息 -->
    <div class="footer__brand">
      <a href={getLocalizedPath('/', lang)} class="footer__logo">
        <svg class="footer__logo-icon" viewBox="0 0 48 48" fill="none">
          <path d="M24 4L4 14V34L24 44L44 34V14L24 4Z" stroke="#00d4ff" stroke-width="2" fill="none"/>
          <path d="M24 14V34M14 19L24 24L34 19" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <circle cx="24" cy="24" r="4" fill="#00d4ff"/>
        </svg>
        <span class="footer__logo-text">LINGFLUX</span>
      </a>
      <p class="footer__description">
        {t('footer.description')}
      </p>
    </div>

    <!-- 友情链接 -->
    <div class="footer__section">
      <h3 class="footer__heading">{t('footer.links')}</h3>
      <ul class="footer__link-list">
        {friendLinks.map(link => (
          <li>
            <a href={link.url} class="footer__link" target="_blank" rel="noopener noreferrer">
              {link.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- 社交媒体 -->
    <div class="footer__section">
      <h3 class="footer__heading">{t('footer.followUs')}</h3>
      <div class="footer__social-links">
        {socialLinks.map(social => (
          <a
            href={social.url}
            class="footer__social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.name}
          >
            <span set:html={socialIcons[social.name]} />
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- 版权信息 -->
  <div class="footer__bottom">
    <p class="footer__copyright">
      &copy; {currentYear} LINGFLUX. {t('footer.allRightsReserved')}
    </p>
  </div>
</footer>

<style>
  /* ============================================
     页脚组件样式
     ============================================ */

  .footer {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
  }

  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 24px 40px;
  }

  /* 三栏网格布局 */
  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  /* 品牌区域 */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer__logo:hover {
    opacity: 0.8;
  }

  .footer__logo-icon {
    width: 32px;
    height: 32px;
    color: var(--color-primary);
  }

  .footer__logo-text {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .footer__description {
    color: var(--color-text-secondary);
    font-size: 14px;
    line-height: 1.6;
    max-width: 280px;
  }

  /* 通用区块样式 */
  .footer__section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__heading {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* 友情链接列表 */
  .footer__link-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__link {
    color: var(--color-text-secondary);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: var(--color-primary);
  }

  /* 社交媒体链接 */
  .footer__social-links {
    display: flex;
    gap: 12px;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    transition: all 0.2s ease;
  }

  .footer__social-link:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  .footer__social-link svg {
    width: 20px;
    height: 20px;
  }

  /* 底部版权 */
  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding: 20px 24px;
    text-align: center;
  }

  .footer__copyright {
    color: var(--color-text-tertiary);
    font-size: 13px;
  }

  /* ============================================
     响应式设计
     ============================================ */

  /* 平板 - 两栏布局 */
  @media (min-width: 640px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .footer__description {
      max-width: 400px;
    }
  }

  /* 桌面 - 三栏布局 */
  @media (min-width: 900px) {
    .footer__inner {
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 60px;
    }

    .footer__brand {
      grid-column: 1 / 2;
      flex-direction: column;
      align-items: flex-start;
    }

    .footer__description {
      max-width: 280px;
    }
  }
</style>
